# ---------- Production build ----------
# 部分网络访问 443 会被重置，生产环境使用 8443（nginx 已配置同证书）
# 生产前端域名（备案中）：https://www.jiadianer.cloud
# API 仍可用 api.jadot.cn:8443，备案完成后可切 api.jiadianer.cloud
VITE_API_BASE=https://api.jadot.cn:8443
VITE_BASE_PATH=/

# ---------- Local development (see .env.development) ----------
# VITE_API_BASE=          # empty => use Vite /api proxy
# VITE_DEV_API_URL=http://127.0.0.1:8080

VITE_GIN_API_URL=http://127.0.0.1:8080
VITE_COS_RESOURCE_MANIFEST_URL=
VITE_COS_PUBLIC_BASE_URL=
VITE_STATIC_MODE=false
# Image push orientation: landscape default 90, optional 0/90/180/270
VITE_USB_ROTATE_DEG=90
# V1PRO 控制工具 Setup 下载地址（未安装 v1pro:// 协议时提示）
# VITE_V1PRO_SETUP_URL=https://v1pro-1311844229.cos.ap-guangzhou.myqcloud.com/佳点V1PRO_Setup.exe

