# ---------- Production build ----------
VITE_API_BASE=https://api.jiadianer.cloud:8443
VITE_BASE_PATH=/

# ---------- Local development (see .env.development) ----------
# VITE_API_BASE=          # empty => use Vite /api proxy
# VITE_DEV_API_URL=http://127.0.0.1:8080

VITE_GIN_API_URL=http://127.0.0.1:8080
VITE_COS_RESOURCE_MANIFEST_URL=
VITE_COS_PUBLIC_BASE_URL=
VITE_STATIC_MODE=false
# Image push orientation: landscape default 90, optional 0/90/180/270
VITE_USB_ROTATE_DEG=90

